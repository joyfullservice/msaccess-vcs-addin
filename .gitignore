# Version Control Add-in Binaries
# (This should be built from source and not committed to version control)
*.mdb
*.accda
*.accdb
*.zip

# Database lock files
*.laccdb

# Ignore VCS log files (stored in logs/ subfolder of source folder)
# Comment out the following lines if you wish to include log files in git.
logs/
*.log

# The local VCS index file is paired with the database and should not
# be committed to version control.
vcs-index.*

# MCP/API session option overrides (transient, per-developer)
mcp/

# Ignore any dotenv files (used for external database connections).
# Includes layered/per-environment variants (.env.local, .env.<APP_ENV>, etc.).
# Templates (*.example) are kept under version control.
*.env
.env.*
!.env*.example

# TwinBasic ribbon project packages
Ribbon/Source/Packages

# VSCode settings
/.vscode
