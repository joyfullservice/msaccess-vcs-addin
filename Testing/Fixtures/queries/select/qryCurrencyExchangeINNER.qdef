dbMemo "SQL" ="SELECT\015\012  tblCurrencies.CurrencyCode,\015\012  tblCurrencies.Cur"
    "rency,\015\012  tblCurrencyExchange.Base,\015\012  tblCurrencyExchange"
    ".Date,\015\012  tblCurrencyExchange.Currency,\015\012  tblCurrencyExch"
    "ange.Rate\015\012FROM\015\012  tblCurrencies\015\012  INNER JOIN tblCu"
    "rrencyExchange ON tblCurrencies.CurrencyCode = tblCurrencyExchange.Cur"
    "rency\015\012ORDER BY\015\012  tblCurrencies.CurrencyCode,\015\012  tb"
    "lCurrencyExchange.Date DESC;\015\012"
