Operation =1
Option =2
Where ="(((tblCars.Manufacturer)=\"Ford\") AND ((tblCars.Year)=2007) AND ((tbl"
    "CarsModel.Model)=\"Altima\") AND ((tblCarsColour.Colour)=\"Orange\"))"
Begin InputTables
    Name ="tblCars"
    Name ="tblCarsModel"
    Name ="tblCarsColour"
    Name ="tblCarsPrice"
End
Begin OutputColumns
    Expression ="tblCars.Manufacturer"
    Expression ="tblCars.Year"
    Expression ="tblCarsModel.Model"
    Expression ="tblCarsColour.Colour"
    Expression ="tblCarsPrice.Price"
End
Begin Joins
    LeftTable ="tblCars"
    RightTable ="tblCarsModel"
    Expression ="tblCars.ID = tblCarsModel.ID"
    Flag =1
    LeftTable ="tblCarsModel"
    RightTable ="tblCarsColour"
    Expression ="tblCarsModel.ID = tblCarsColour.ID"
    Flag =1
    LeftTable ="tblCarsColour"
    RightTable ="tblCarsPrice"
    Expression ="tblCarsColour.ID = tblCarsPrice.ID"
    Flag =1
End
dbBoolean "ReturnsRecords" ="-1"
dbInteger "ODBCTimeout" ="60"
dbByte "RecordsetType" ="0"
dbBoolean "OrderByOn" ="0"
dbByte "Orientation" ="0"
dbByte "DefaultView" ="2"
dbBoolean "FilterOnLoad" ="0"
dbBoolean "OrderByOnLoad" ="-1"
dbBoolean "TotalsRow" ="0"
Begin
    Begin
        dbText "Name" ="tblCars.Manufacturer"
        dbLong "AggregateType" ="-1"
    End
    Begin
        dbText "Name" ="tblCars.Year"
        dbLong "AggregateType" ="-1"
    End
    Begin
        dbText "Name" ="tblCarsModel.Model"
        dbLong "AggregateType" ="-1"
    End
    Begin
        dbText "Name" ="tblCarsColour.Colour"
        dbLong "AggregateType" ="-1"
    End
    Begin
        dbText "Name" ="tblCarsPrice.Price"
        dbLong "AggregateType" ="-1"
    End
End
