dbMemo "SQL" ="SELECT DISTINCT\015\012  tblCars.Manufacturer,\015\012  tblCars.Year,"
    "\015\012  tblCarsModel.Model,\015\012  tblCarsColour.Colour,\015\012  "
    "tblCarsPrice.Price\015\012FROM\015\012  (\015\012    (\015\012      tb"
    "lCars\015\012      INNER JOIN tblCarsModel ON tblCars.ID = tblCarsMode"
    "l.ID\015\012    )\015\012    INNER JOIN tblCarsColour ON tblCarsModel."
    "ID = tblCarsColour.ID\015\012  )\015\012  INNER JOIN tblCarsPrice ON t"
    "blCarsColour.ID = tblCarsPrice.ID;\015\012"
