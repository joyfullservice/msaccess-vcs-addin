dbMemo "SQL" ="SELECT\015\012  tblCars.Manufacturer,\015\012  tblCarsModel.Model,\015"
    "\012  tblCurrencies.CurrencyCode\015\012FROM\015\012  (\015\012    tbl"
    "Cars\015\012    INNER JOIN tblCarsModel ON tblCars.ID = tblCarsModel.I"
    "D\015\012  ),\015\012  tblCurrencies;\015\012"
