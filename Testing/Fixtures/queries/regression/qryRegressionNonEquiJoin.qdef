Operation =1
Option =0
Where ="(((A.MeterFK)<=1) AND ((B.Estimate)=False) AND ((A.Estimate)=False))"
Begin InputTables
    Name ="tblMeterReadings"
    Alias ="A"
    Name ="tblMeterReadings"
    Alias ="B"
End
Begin OutputColumns
    Expression ="A.MeterFK"
    Expression ="A.ReadingDate"
    Expression ="A.Reading"
    Expression ="B.ReadingDate"
    Expression ="B.Reading"
    Alias ="days"
    Expression ="[a].[readingdate]-[b].[readingdate]"
    Alias ="used"
    Expression ="[A].[reading]-[b].[reading]-(100000*([a].[readingdate]=#11/12/2020#))"
    Alias ="perday"
    Expression ="[used]/[days]"
End
Begin Joins
    LeftTable ="A"
    RightTable ="B"
    Expression ="A.MeterFK = B.MeterFK"
    Flag =1
    LeftTable ="A"
    RightTable ="B"
    Expression ="A.Reading > B.ReadingDate"
    Flag =1
End
