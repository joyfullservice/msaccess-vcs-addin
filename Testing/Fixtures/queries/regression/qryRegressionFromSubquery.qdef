dbMemo "SQL" ="SELECT\015\012  [%$##@_Alias].Manufacturer,\015\012  [%$##@_Alias].Mod"
    "elLabel,\015\012  [%$##@_Alias].Year,\015\012  [%$##@_Alias].Price,"
    "\015\012  UCase([%$##@_Alias].Colour) AS ColourUpper\015\012FROM\015"
    "\012  (\015\012    SELECT\015\012      tblCars.ID,\015\012      tblCar"
    "s.Manufacturer,\015\012      tblCars.Year,\015\012      (\015\012     "
    "   tblCars.Manufacturer & ' ' & tblCarsModel.Model\015\012      ) AS M"
    "odelLabel,\015\012      tblCarsColour.Colour,\015\012      tblCarsPric"
    "e.Price\015\012    FROM\015\012      (\015\012        (\015\012       "
    "   tblCars\015\012          INNER JOIN tblCarsModel ON tblCars.ID = tb"
    "lCarsModel.ID\015\012        )\015\012        INNER JOIN tblCarsColour"
    " ON tblCarsModel.ID = tblCarsColour.ID\015\012      )\015\012      INN"
    "ER JOIN tblCarsPrice ON tblCarsColour.ID = tblCarsPrice.ID\015\012    "
    "WHERE\015\012      tblCars.Year >= 2000\015\012      AND tblCarsPrice."
    "Price > 0\015\012      AND tblCars.ID IN (\015\012        SELECT\015"
    "\012          ID\015\012        FROM\015\012          tblCarsColour"
    "\015\012        WHERE\015\012          Colour IN ('Red', 'Blue')\015"
    "\012      )\015\012    ORDER BY\015\012      tblCars.Manufacturer\015"
    "\012  ) AS [%$##@_Alias];\015\012"
dbMemo "Connect" =""
dbBoolean "ReturnsRecords" ="-1"
dbInteger "ODBCTimeout" ="60"
dbByte "RecordsetType" ="0"
dbBoolean "OrderByOn" ="0"
dbByte "Orientation" ="0"
dbByte "DefaultView" ="2"
dbBoolean "FilterOnLoad" ="0"
dbBoolean "OrderByOnLoad" ="-1"
dbBoolean "TotalsRow" ="0"
