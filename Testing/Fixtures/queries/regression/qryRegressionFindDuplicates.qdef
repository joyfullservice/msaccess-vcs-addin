dbMemo "SQL" ="SELECT\015\012  tblCars.Manufacturer,\015\012  tblCars.Year,\015\012  "
    "tblCars.ID\015\012FROM\015\012  tblCars\015\012WHERE\015\012  (\015"
    "\012    (\015\012      (tblCars.Manufacturer) In (\015\012        SELE"
    "CT\015\012          [Manufacturer]\015\012        FROM\015\012        "
    "  [tblCars] AS Tmp\015\012        GROUP BY\015\012          [Manufactu"
    "rer]\015\012        HAVING\015\012          Count(*)> 1\015\012      )"
    "\015\012    )\015\012  )\015\012ORDER BY\015\012  tblCars.Manufacturer"
    ";\015\012"
