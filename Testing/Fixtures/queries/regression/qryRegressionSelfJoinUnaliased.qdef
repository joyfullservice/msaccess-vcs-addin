dbMemo "SQL" ="SELECT\015\012  tblCars.Manufacturer AS PrimaryMake,\015\012  tblCars_"
    "1.Manufacturer AS SiblingMake,\015\012  tblCars.Year\015\012FROM\015"
    "\012  tblCars\015\012  INNER JOIN tblCars AS tblCars_1 ON tblCars.Year"
    " = tblCars_1.Year\015\012WHERE\015\012  (\015\012    (\015\012      (t"
    "blCars.ID < tblCars_1.ID)\015\012    )\015\012  );\015\012"
