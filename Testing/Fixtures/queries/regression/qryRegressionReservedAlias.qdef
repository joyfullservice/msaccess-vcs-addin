dbMemo "SQL" ="SELECT\015\012  tblCars.ID,\015\012  tblCars.Manufacturer,\015\012  [M"
    "anufacturer] & \"|\" & [ID] AS [Key],\015\012  1 AS [Action],\015\012 "
    " tblCars.Year AS [Year],\015\012  tblCars.Model AS [Names],\015\012  t"
    "blCars.Colour AS [Number],\015\012  \"USD\" AS [Currency]\015\012FROM"
    "\015\012  tblCars;\015\012"
