dbMemo "SQL" ="PARAMETERS [Select Manufacturer] Text (255);\015\012TRANSFORM\015\012 "
    " Count(qryCars.Colour) AS CountOfColour\015\012SELECT\015\012  qryCars"
    ".Manufacturer\015\012FROM\015\012  qryCars\015\012WHERE\015\012  (\015"
    "\012    (\015\012      (qryCars.Manufacturer)= [Select Manufacturer]"
    "\015\012    )\015\012  )\015\012GROUP BY\015\012  qryCars.Manufacturer"
    "\015\012ORDER BY\015\012  qryCars.Manufacturer\015\012PIVOT\015\012  q"
    "ryCars.Model;\015\012"
