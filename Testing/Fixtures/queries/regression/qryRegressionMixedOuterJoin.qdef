dbMemo "SQL" ="SELECT\015\012  tblCars.Manufacturer,\015\012  tblCarsModel.Model,\015"
    "\012  tblCarsColour.Colour\015\012FROM\015\012  (\015\012    tblCars"
    "\015\012    LEFT JOIN tblCarsModel ON tblCars.ID = tblCarsModel.ID\015"
    "\012  )\015\012  RIGHT JOIN tblCarsColour ON tblCarsColour.ID = tblCar"
    "s.ID;\015\012"
