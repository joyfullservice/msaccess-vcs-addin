dbMemo "SQL" ="SELECT\015\012  tblCars.ID,\015\012  tblCars.Manufacturer,\015\012  tb"
    "lCarsModel.Model,\015\012  tblCarsColour.Colour,\015\012  carCopy.Manu"
    "facturer AS DuplicateManufacturer\015\012FROM\015\012  (\015\012    ("
    "\015\012      tblCars\015\012      INNER JOIN tblCarsModel ON tblCars."
    "ID = tblCarsModel.ID\015\012    )\015\012    INNER JOIN tblCarsColour "
    "ON tblCars.ID = tblCarsColour.ID\015\012  )\015\012  LEFT JOIN tblCars"
    " AS carCopy ON tblCars.Manufacturer = carCopy.Manufacturer;\015\012"
